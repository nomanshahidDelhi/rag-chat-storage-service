# ---- API authentication ----
# Shared secret required on every /api/** request via the X-API-Key header.
API_KEY=changeme-super-secret-key

# ---- Database ----
# DB_HOST is only used by the 'dev' profile (running outside Docker); defaults to localhost.
# DB_HOST=localhost
POSTGRES_DB=ragchat
POSTGRES_USER=ragchat
POSTGRES_PASSWORD=ragchat
POSTGRES_PORT=5432
# ---- Application ----
SPRING_PROFILES_ACTIVE=docker
APP_PORT=8080
ALLOWED_ORIGINS=http://localhost:3000

# ---- Rate limiting (Bucket4j, per client IP) ----
RATE_LIMIT_CAPACITY=60
RATE_LIMIT_REFILL_SECONDS=60

# ---- pgAdmin (dockerized DB management tool) ----
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=admin
PGADMIN_PORT=5050
